<launch>
  <!-- ============================================================
       mrrep_bridge 一键启动
       用法:
         roslaunch mrrep_bridge start.launch mode:=nav   map_name:=你的地图
         roslaunch mrrep_bridge start.launch mode:=map
         roslaunch mrrep_bridge start.launch mode:=teleop

       所有模式都起: rosbridge(:9090) + twist_mux
       WebRop 始终连 ws://机器人IP:9090；键盘走 /teleop_vel → twist_mux → /cmd_vel → 底盘
       导航模式下按 WebRop 键盘可立即手动接管，松手 0.5s 回自主。
       ============================================================ -->

  <arg name="mode"         default="nav" doc="nav / map / teleop"/>
  <arg name="map_name"     default=""/>
  <arg name="map_file"     default=""/>
  <arg name="ep_sn"        default=""/>
  <arg name="ep_conn_type" default="rndis" doc="ap(WiFi直连) / sta(路由器) / rndis(USB)"/>
  <arg name="ep_ip"        default=""/>
  <arg name="use_hi12"     default="true"/>
  <arg name="rviz"         default="false"/>

  <!-- ===== 公共：rosbridge（WebRop 网关）===== -->
  <include file="$(find rosbridge_server)/launch/rosbridge_websocket.launch">
    <arg name="port" value="9090"/>
  </include>

  <!-- ===== 公共：twist_mux（手动 /teleop_vel 优先，自动 /cmd_vel_raw 次之 → /cmd_vel）===== -->
  <node name="twist_mux" pkg="twist_mux" type="twist_mux" output="screen">
    <rosparam file="$(find mrrep_bridge)/config/twist_mux.yaml" command="load"/>
    <remap from="cmd_vel" to="/cmd_vel"/>
  </node>

  <!-- ============================================================
       nav 模式：自主导航 + WebRop 画路径 + 可随时手动接管
       ============================================================ -->
  <group if="$(eval mode == 'nav')">
    <include file="$(find rm_ep_navigation)/launch/navigation.launch">
      <arg name="map_name"      value="$(arg map_name)"/>
      <arg name="map_file"      value="$(arg map_file)"/>
      <arg name="ep_sn"         value="$(arg ep_sn)"/>
      <arg name="ep_conn_type"  value="$(arg ep_conn_type)"/>
      <arg name="ep_ip"         value="$(arg ep_ip)"/>
      <arg name="use_hi12"      value="$(arg use_hi12)"/>
      <arg name="rviz"          value="$(arg rviz)"/>
      <!-- move_base 速度先经 twist_mux；navigation.launch 默认仍发 /cmd_vel，向后兼容 -->
      <arg name="cmd_vel_topic" value="cmd_vel_raw"/>
    </include>
    <node name="hrp_follower_node" pkg="mrrep_bridge" type="hrp_follower_node.py" output="screen"/>
  </group>

  <!-- ============================================================
       map 模式：gmapping 建图 + WebRop 键盘驱动 + 桥接存图
       （无 move_base，WebRop 键盘 /teleop_vel 经 twist_mux 直达底盘，不冲突）
       ============================================================ -->
  <group if="$(eval mode == 'map')">
    <include file="$(find rm_ep_navigation)/launch/mapping.launch">
      <arg name="ep_sn"         value="$(arg ep_sn)"/>
      <arg name="ep_conn_type"  value="$(arg ep_conn_type)"/>
      <arg name="ep_ip"         value="$(arg ep_ip)"/>
      <arg name="use_hi12"      value="$(arg use_hi12)"/>
      <arg name="rviz"          value="$(arg rviz)"/>
    </include>
    <!-- 听 /webrop/slam_command，收到 stop/save 就调 save_map.sh 存图 -->
    <node name="slam_bridge" pkg="mrrep_bridge" type="slam_bridge.py" output="screen"/>
  </group>

  <!-- ============================================================
       teleop 模式：底盘 + 雷达 + EKF，纯手动（无导航无建图，带激光显示）
       ============================================================ -->
  <group if="$(eval mode == 'teleop')">
    <include file="$(find rm_ep_description)/launch/description.launch"/>
    <node name="rplidarNode" pkg="rplidar_ros" type="rplidarNode" output="screen">
      <param name="serial_port"      type="string" value="/dev/rplidar"/>
      <param name="serial_baudrate"  type="int"    value="256000"/>
      <param name="frame_id"         type="string" value="laser_link"/>
      <param name="inverted"         type="bool"   value="false"/>
      <param name="angle_compensate" type="bool"   value="true"/>
    </node>
    <include file="$(find rm_ep_driver)/launch/rm_ep_chassis_bringup.launch">
      <arg name="ep_sn"          value="$(arg ep_sn)"/>
      <arg name="ep_conn_type"   value="$(arg ep_conn_type)"/>
      <arg name="ep_ip"          value="$(arg ep_ip)"/>
      <arg name="enable_cmd_vel" value="true"/>
      <arg name="enable_imu"     value="$(eval not arg('use_hi12'))"/>
    </include>
    <node if="$(arg use_hi12)" name="hi12_imu_node" pkg="rm_ep_driver" type="hi12_imu_node.py" output="screen">
      <param name="port"         value="/dev/hi12_imu"/>
      <param name="baud"         value="115200"/>
      <param name="frame_id"     value="imu_link"/>
      <param name="publish_rate" value="50"/>
    </node>
    <node name="ekf_localization" pkg="robot_localization" type="ekf_localization_node" output="screen">
      <rosparam file="$(find rm_ep_navigation)/config/ekf.yaml" command="load"/>
    </node>
  </group>
</launch>
